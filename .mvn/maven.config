# Maven per-connection timeouts. Keep them aggressive so any slow/unreachable
# repository fails fast and Maven moves on to the next configured repo rather
# than hanging the build. See pom.xml for the repository list and comment.
#
# Both wagon.* and aether.* keys included for compatibility with Maven 3.8
# (Wagon transport) and 3.9+ (native maven-resolver-transport-http).

-Dmaven.wagon.http.connectionTimeout=10000
-Dmaven.wagon.http.readTimeout=30000
-Dmaven.wagon.httpconnectionManager.ttlSeconds=120
-Dmaven.wagon.http.retryHandler.count=3
-Daether.connector.connectTimeout=10000
-Daether.connector.requestTimeout=30000
